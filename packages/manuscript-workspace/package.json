{
  "name": "@ai-focused-editor/manuscript-workspace",
  "version": "0.1.0",
  "description": "First-party Theia extension for AI Focused Editor manuscript workspace MVP.",
  "keywords": [
    "theia-extension"
  ],
  "license": "UNLICENSED",
  "files": [
    "lib",
    "src"
  ],
  "main": "lib/common/index.js",
  "typings": "lib/common/index.d.ts",
  "dependencies": {
    "@ai-focused-editor/ai-connect-theia": "workspace:*",
    "@ai-focused-editor/book-export": "0.1.0",
    "@ai-focused-editor/document-preview-theia": "workspace:*",
    "@ai-focused-editor/semantic-markdown": "workspace:*",
    "@excalidraw/excalidraw": "0.18.1",
    "@theia/ai-chat": "1.73.1",
    "@theia/ai-core": "1.73.1",
    "@theia/ai-mcp": "1.73.1",
    "@theia/core": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/markers": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/monaco-editor-core": "1.108.201",
    "@theia/navigator": "1.73.1",
    "@theia/output": "1.73.1",
    "@theia/process": "1.73.1",
    "@theia/task": "1.73.1",
    "@theia/workspace": "1.73.1",
    "@vedmalex/ai-connect": "^0.13.0",
    "ajv": "8.20.0",
    "cropperjs": "^1.6.2",
    "jsonc-parser": "3.3.1",
    "katex": "^0.16.11",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.3.0",
    "unpdf": "1.6.2",
    "wavesurfer.js": "^7.12.5",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.0.10",
    "reflect-metadata": "0.2.2",
    "typescript": "~5.8.3"
  },
  "scripts": {
    "docs:inventory": "bun scripts/extract-feature-inventory.mjs",
    "docs:gen:strict": "bun scripts/generate-docs-content.mjs --coverage=strict",
    "docs:gen:warn": "bun scripts/generate-docs-content.mjs --coverage=warn",
    "docs:strict": "bun run docs:inventory && bun run docs:gen:strict",
    "docs:dev": "bun run docs:inventory && bun run docs:gen:warn",
    "compile": "rm -rf lib && tsc && mkdir -p lib/browser/themes && cp src/browser/themes/*.json lib/browser/themes/ && mkdir -p lib/node/i18n/ru && cp src/node/i18n/ru/*.json lib/node/i18n/ru/ && mkdir -p lib/node/ai && cp src/node/ai/*.yaml lib/node/ai/",
    "build": "bun run docs:strict && bun run compile",
    "build:dev": "bun run docs:dev && bun run compile",
    "clean": "rm -rf lib *.tsbuildinfo docs-inventory.generated.json src/browser/docs/docs-content.generated.ts",
    "watch": "bun run docs:dev && tsc -w"
  },
  "theiaExtensions": [
    {
      "frontend": "lib/browser/manuscript-workspace-frontend-module",
      "backend": "lib/node/manuscript-workspace-backend-module"
    },
    {
      "frontend": "lib/browser/author-materials-create-frontend-module"
    },
    {
      "frontend": "lib/browser/entity-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/excalidraw-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/proofreading-frontend-module"
    },
    {
      "frontend": "lib/browser/proofreading-mode-frontend-module"
    },
    {
      "frontend": "lib/browser/transcript-check-frontend-module"
    },
    {
      "frontend": "lib/browser/image-viewer-frontend-module"
    },
    {
      "frontend": "lib/browser/media-viewer-frontend-module"
    },
    {
      "frontend": "lib/browser/citation-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/excerpts-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/ai-modes-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/entity-types-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/book-config-editor-frontend-module"
    },
    {
      "frontend": "lib/browser/knowledge-generation-frontend-module"
    },
    {
      "frontend": "lib/browser/ai-mode-dynamic-frontend-module"
    },
    {
      "frontend": "lib/browser/narrative-graph-frontend-module"
    },
    {
      "frontend": "lib/browser/semantic-history-frontend-module"
    },
    {
      "frontend": "lib/browser/live-validation-frontend-module"
    },
    {
      "frontend": "lib/browser/writer-icon-theme-frontend-module"
    },
    {
      "frontend": "lib/browser/bundled-color-themes-frontend-module"
    },
    {
      "frontend": "lib/browser/book-build-wizard-frontend-module"
    },
    {
      "frontend": "lib/browser/book-doctor-frontend-module"
    },
    {
      "frontend": "lib/browser/transcription-settings-frontend-module"
    },
    {
      "frontend": "lib/browser/welcome-frontend-module"
    },
    {
      "frontend": "lib/browser/chat-capability-presets-frontend-module"
    },
    {
      "frontend": "lib/browser/mcp-controls-frontend-module"
    },
    {
      "frontend": "lib/browser/auth-qr-frontend-module"
    }
  ]
}
