{
  "private": true,
  "name": "@ai-focused-editor/browser",
  "version": "0.1.0",
  "dependencies": {
    "@ai-focused-editor/ai-connect-theia": "workspace:*",
    "@ai-focused-editor/git": "0.1.0",
    "@ai-focused-editor/manuscript-workspace": "workspace:*",
    "@parcel/watcher-darwin-arm64": "2.5.6",
    "@theia/ai-chat": "1.73.1",
    "@theia/ai-chat-ui": "1.73.1",
    "@theia/ai-code-completion": "1.73.1",
    "@theia/ai-core": "1.73.1",
    "@theia/ai-ide": "1.73.1",
    "@theia/ai-mcp": "1.73.1",
    "@theia/ai-terminal": "1.73.1",
    "@theia/console": "1.73.1",
    "@theia/core": "1.73.1",
    "@theia/debug": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/editor-preview": "1.73.1",
    "@theia/file-search": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/markers": "1.73.1",
    "@theia/messages": "1.73.1",
    "@theia/mini-browser": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/monaco-editor-core": "1.108.201",
    "@theia/navigator": "1.73.1",
    "@theia/outline-view": "1.73.1",
    "@theia/output": "1.73.1",
    "@theia/preferences": "1.73.1",
    "@theia/process": "1.73.1",
    "@theia/scm": "1.73.1",
    "@theia/scm-extra": "1.73.1",
    "@theia/search-in-workspace": "1.73.1",
    "@theia/task": "1.73.1",
    "@theia/terminal": "1.73.1",
    "@theia/test": "1.73.1",
    "@theia/userstorage": "1.73.1",
    "@theia/variable-resolver": "1.73.1",
    "@theia/workspace": "1.73.1",
    "@vscode/ripgrep-darwin-arm64": "1.18.0",
    "node-pty": "1.2.0-beta.12",
    "reflect-metadata": "^0.2.2",
    "trash": "^7.2.0"
  },
  "devDependencies": {
    "@theia/bundle-plugin": "1.73.1",
    "@theia/cli": "1.73.1",
    "esbuild": "^0.25.6",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugins-node-modules-polyfill": "^1.8.2",
    "resolve-package-path": "^4.0.3",
    "yargs": "^18.0.0"
  },
  "scripts": {
    "bundle": "bun run rebuild && theia build --mode development && node ../../scripts/copy-excalidraw-assets.mjs browser && node ../../scripts/copy-katex-assets.mjs browser && node ../../scripts/copy-obsidian-plugin-assets.mjs browser",
    "rebuild": "theia rebuild:browser --cacheRoot ../..",
    "start": "theia start --hostname 0.0.0.0 ../../examples/sample-book",
    "watch": "bun run rebuild && theia build --watch --mode development"
  },
  "theia": {
    "target": "browser",
    "frontend": {
      "applicationName": "AI Focused Editor",
      "config": {
        "defaultIconTheme": "afe-writer-icons",
        "preferences": {
          "files.autoSave": "afterDelay",
          "files.autoSaveDelay": 1000,
          "files.exclude": {
            "**/.git": true,
            "**/build": true,
            "**/.llm-wiki": true
          },
          "workbench.tree.renderIndentGuides": "onHover",
          "ai-features.AiEnable.enableAI": true,
          "ai-features.codeCompletion.automaticCodeCompletion": false,
          "security.workspace.trust.enabled": false
        }
      }
    }
  }
}
